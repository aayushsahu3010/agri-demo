# ─── App Settings ──────────────────────────────────────────────
APP_NAME=CROOPIC
APP_VERSION=1.0.0
DEBUG=True
SECRET_KEY=your-super-secret-key-change-in-production

# ─── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/croopic_db

# ─── AI Model ──────────────────────────────────────────────────
MODEL_PATH=./ai_model/weights/croopic_model.pt
MODEL_ARCHITECTURE=efficientnet_b4      # efficientnet_b4 | vit_base | resnet50 | yolov8
CONFIDENCE_THRESHOLD=0.70
NUM_CLASSES=38                           # PlantVillage has 38 disease classes

# ─── AWS S3 ────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=ap-south-1
S3_BUCKET_NAME=croopic-leaf-images

# ─── Auth ──────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080       # 7 days

# ─── Razorpay ──────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret

# ─── CORS ──────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:8081", "exp://localhost:8081"]
